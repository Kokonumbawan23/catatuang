{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "composer install --no-dev --no-progress",
    "startCommand": "php artisan serve --port=$PORT"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "database": {
    "default": "sqlite"
  }
}
